# Flask Configuration
# If any keys were shared or exposed, rotate them and update .env (see ROTATE_KEYS.md).
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=mysql+pymysql://root:@localhost/irequest
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=irequest

# AWS Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-2
S3_BUCKET_NAME=your-s3-bucket

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Groq AI Configuration (for receipt reference number verification)
GROQ_API_KEY=your-groq-api-key

# Application Settings
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads/documents
USE_LOCAL_DB=false

# Staff signup: unlisted path in production; link on login is hidden unless enabled
# STAFF_SIGNUP_PATH=/join-staff-secure
# SHOW_STAFF_SIGNUP_LINK=false